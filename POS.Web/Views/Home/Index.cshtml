@using POS.Application.ViewModels
@model DashboardViewModel

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between bg-white p-3 rounded-4 shadow-sm">
                <div>
                    <h3 class="fw-bold mb-1 text-dark">
                        <i class="fas fa-desktop me-2 text-primary"></i>لوحة التحكم
                    </h3>
                    <p class="text-muted mb-0 small">إحصائيات النشاط اليومي ليوم @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
                </div>
                <div class="text-end">
                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                        <i class="fas fa-clock me-1"></i> آخر تحديث: @DateTime.Now.ToString("t")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden">
                <div class="card-body p-4" style="background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);">
                    <div class="d-flex justify-content-between align-items-center text-white">
                        <div>
                            <h6 class="text-white-50 small text-uppercase">مبيعات اليوم</h6>
                            <h2 class="fw-bold mb-0">@Model.TodaySales.ToString("N2")</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-hand-holding-usd fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden">
                <div class="card-body p-4" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                    <div class="d-flex justify-content-between align-items-center text-white">
                        <div>
                            <h6 class="text-white-50 small text-uppercase">مشتريات اليوم</h6>
                            <h2 class="fw-bold mb-0">@Model.TodayPurchasesCount</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-file-invoice fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Reports" asp-action="LowStock" class="text-decoration-none h-100">
                <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden">
                    <div class="card-body p-4 @(Model.LowStockCount > 0 ? "bg-danger bg-gradient" : "bg-secondary bg-gradient")">
                        <div class="d-flex justify-content-between align-items-center text-white">
                            <div>
                                <h6 class="text-white-50 small text-uppercase">تنبيه النواقص</h6>
                                <h2 class="fw-bold mb-0">@Model.LowStockCount</h2>
                            </div>
                            <div class="bg-white bg-opacity-25 rounded-circle p-3">
                                <i class="fas fa-exclamation-triangle fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden">
                <div class="card-body p-4" style="background: linear-gradient(135deg, #232526 0%, #414345 100%); border-right: 5px solid #ffc107;">
                    <div class="d-flex justify-content-between align-items-center text-white">
                        <div>
                            <h6 class="text-warning small text-uppercase fw-bold">رصيد الصندوق الآن</h6>
                            <h2 class="fw-bold mb-0 text-warning">@Model.BoxBalance.ToString("N2")</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-vault fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12 mb-3">
            <h5 class="fw-bold text-secondary">الوصول السريع</h5>
        </div>
        <div class="col-md-4">
            <a asp-controller="Sales" asp-action="Create" class="btn btn-white shadow-sm w-100 py-3 rounded-4 border-0 text-start px-4">
                <i class="fas fa-plus-circle text-primary me-2"></i> عملية بيع جديدة
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Purchases" asp-action="Create" class="btn btn-white shadow-sm w-100 py-3 rounded-4 border-0 text-start px-4">
                <i class="fas fa-truck text-success me-2"></i> إضافة فاتورة شراء
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Products" asp-action="Index" class="btn btn-white shadow-sm w-100 py-3 rounded-4 border-0 text-start px-4">
                <i class="fas fa-barcode text-dark me-2"></i> إدارة المنتجات
            </a>
        </div>
    </div>
</div>

<style>
    .btn-white {
        background-color: white;
        transition: transform 0.2s;
    }

        .btn-white:hover {
            transform: translateY(-5px);
            background-color: #fcfcfc;
        }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: scale(1.02);
        }
</style>