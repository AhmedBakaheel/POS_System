@model POS.Application.DTOs.SaleDTO

@{
    ViewData["Title"] = "نقطة البيع الاحترافية - مبيعات ومرتجعات";
}

<div class="container-fluid mt-2">
    <div class="row">
        <div class="col-lg-8">
            <div id="quick-info" class="alert alert-dark bg-gradient text-white shadow-sm d-flex justify-content-between align-items-center d-none mb-2 py-2">
                <div>
                    <span class="badge bg-warning text-dark me-2">آخر منتج:</span>
                    <span id="last-product-name" class="fw-bold h5">---</span>
                </div>
                <div class="d-flex gap-4">
                    <span>السعر: <strong id="last-product-price" class="text-warning en-numbers">0.00</strong></span>
                    <span>المخزون: <strong id="last-product-stock" class="text-info en-numbers">0</strong></span>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-1">
                    <span class="small">
                        <i class="fas fa-keyboard me-1"></i> F10: حفظ | F2: بحث |
                        <button class="btn btn-sm btn-warning ms-3 fw-bold" data-bs-toggle="modal" data-bs-target="#returnModal">
                            <i class="fas fa-undo me-1"></i> مرتجع مبيعات (F4)
                        </button>
                    </span>
                    <div class="d-flex align-items-center gap-3">
                        <div id="live-clock" class="fw-bold en-numbers small"></div>
                        <a asp-controller="Cashier" asp-action="CloseShift" class="btn btn-sm btn-danger fw-bold shadow-sm">
                            <i class="fas fa-power-off me-1"></i> إغلاق الوردية
                        </a>
                    </div>
                    <div id="live-clock" class="fw-bold en-numbers small"></div>
                </div>

                <div class="card-body p-3">
                    <div class="position-relative mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-warning border-0"><i class="fas fa-search"></i></span>
                            <input type="text" id="barcode-input" class="form-control form-control-lg border-0 bg-light shadow-none fw-bold" placeholder="امسح الباركود أو ابحث بالاسم (مثال: 5*باركود للكمية)..." autocomplete="off" autofocus>
                        </div>
                        <div id="search-results" class="list-group position-absolute w-100 shadow-lg d-none" style="z-index: 1050; max-height: 250px; overflow-y: auto;"></div>
                    </div>

                    <div class="table-responsive" style="height: 55vh; overflow-y: auto;">
                        <table class="table table-hover border text-center align-middle">
                            <thead class="bg-light sticky-top">
                                <tr>
                                    <th class="text-start">المنتج</th>
                                    <th style="width: 100px;">السعر</th>
                                    <th style="width: 160px;">الكمية</th>
                                    <th style="width: 100px;">الإجمالي</th>
                                    <th style="width: 40px;"></th>
                                </tr>
                            </thead>
                            <tbody id="cart-items-body" class="en-numbers"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-lg border-0 h-100 bg-dark text-white">
                <div class="card-body d-flex flex-column">
                    <h5 class="text-center text-secondary border-bottom border-secondary pb-3 mb-3">ملخص الفاتورة</h5>

                    <div class="mb-3 text-start">
                        <label class="small text-secondary mb-1">طريقة الدفع:</label>
                        <select id="payment-type" class="form-select bg-secondary text-white border-0 shadow-none">
                            <option value="1">نقدي (Cash)</option>
                            <option value="2">آجل (Credit)</option>
                        </select>
                    </div>

                    <div id="customer-box" class="mb-3 d-none text-start">
                        <label class="small text-secondary mb-1">اختيار العميل:</label>
                        <select id="customer-id" class="form-select border-0 shadow-none" asp-items="ViewBag.Customers">
                            <option value="">-- اختر العميل --</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-between h6 mb-3 en-numbers text-secondary">
                        <span>إجمالي الأصناف:</span>
                        <span id="items-count" class="text-info">0</span>
                    </div>

                    <div class="text-center py-4 rounded bg-black mb-4 border border-secondary shadow-inner">
                        <small class="text-uppercase text-secondary">إجمالي المطلوب للدفع</small>
                        <h1 class="display-3 fw-bold text-warning mb-0 en-numbers" id="grand-total">0.00</h1>
                    </div>

                    <div class="mt-auto">
                        <button class="btn btn-success btn-lg w-100 py-3 mb-2 fw-bold fs-3 shadow" id="btn-complete-sale">
                            إتمام وطباعة (F10)
                        </button>
                        <button class="btn btn-outline-danger w-100 py-2" onclick="location.reload()">
                            <i class="fas fa-trash-alt me-2"></i> إلغاء الفاتورة
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="fas fa-undo me-2"></i> معالجة مرتجع مبيعات</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="number" id="return-sale-id" class="form-control" placeholder="أدخل رقم الفاتورة الأصلية...">
                    <button class="btn btn-primary" id="btn-find-sale">بحث عن الفاتورة</button>
                </div>
                <div id="return-details" class="d-none">
                    <table class="table table-sm table-bordered">
                        <thead class="bg-light">
                            <tr>
                                <th>الصنف</th>
                                <th>المباع</th>
                                <th width="120">كمية المرتجع</th>
                                <th>المبلغ</th>
                            </tr>
                        </thead>
                        <tbody id="return-items-body"></tbody>
                    </table>
                    <div class="mb-3">
                        <label class="small fw-bold">سبب المرتجع:</label>
                        <input type="text" id="return-reason" class="form-control" placeholder="مثال: تالف أو رغبة العميل">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" class="btn btn-danger d-none" id="btn-submit-return">تأكيد المرتجع وحفظ</button>
            </div>
        </div>
    </div>
</div>

<div id="print-receipt" class="d-none">
    <div style="width: 80mm; font-family: 'Arial'; direction: rtl; padding: 5px;">
        <div style="text-align: center;">
            <h4 style="margin:0;">فاتورة مبيعات</h4>
            <p style="font-size:12px;">كاشير: @User.Identity.Name | وردية: #@ViewBag.ShiftId</p>
        </div>
        <hr style="border-top: 1px dashed #000;">
        <div class="en-numbers" style="font-size: 11px;">
            <div>التاريخ: <span id="p-date"></span></div>
            <div>نوع الدفع: <span id="p-type"></span></div>
            <div id="p-customer-row">العميل: <span id="p-customer"></span></div>
        </div>
        <table style="width: 100%; font-size: 12px; margin-top: 10px; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px solid #000;">
                    <th style="text-align: right;">الصنف</th>
                    <th style="text-align: center;">كمية</th>
                    <th style="text-align: left;">مجموع</th>
                </tr>
            </thead>
            <tbody id="p-items"></tbody>
        </table>
        <hr style="border-top: 1px dashed #000;">
        <div style="text-align: center; font-size: 16px; font-weight: bold;">
            المطلوب: <span id="p-total" class="en-numbers"></span>
        </div>
        <p style="text-align: center; font-size: 10px; margin-top: 10px;">شكراً لزيارتكم!</p>
    </div>
</div>

<style>
    .en-numbers {
        font-family: 'Segoe UI', Arial, sans-serif !important;
        direction: ltr !important;
    }

    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);
    }

    #cart-items-body tr {
        vertical-align: middle;
    }

    #search-results .list-group-item:hover {
        cursor: pointer;
        background-color: #f8f9fa;
    }

    .btn-qty {
        width: 35px;
        height: 35px;
        padding: 0;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let cart = [];
        let pendingQty = 1;
        const currentShiftId = @(ViewBag.ShiftId ?? 0);

        $(document).ready(function () {
            if (currentShiftId === 0) {
                Swal.fire('تنبيه', 'لا توجد وردية مفتوحة!', 'warning').then(() => window.location.href = '/Cashier/OpenShift');
                return;
            }

            setInterval(() => { $('#live-clock').text(new Date().toLocaleTimeString('en-US')); }, 1000);
            $('#barcode-input').focus();

            $('#payment-type').change(function() {
                $('#payment-type').val() === "2" ? $('#customer-box').removeClass('d-none') : $('#customer-box').addClass('d-none');
            });

            $('#barcode-input').on('input', function() {
                let val = $(this).val().trim();
                let searchTerm = val;
                if (val.includes('*')) {
                    let parts = val.split('*');
                    pendingQty = parseFloat(parts[0]) || 1;
                    searchTerm = parts[1];
                } else { pendingQty = 1; }

                if (searchTerm.length >= 2) {
                    $.get('/Sales/SearchProducts?term=' + searchTerm, function(data) { renderSearchList(data); });
                } else { $('#search-results').addClass('d-none'); }
            });

            window.renderSearchList = function(products) {
                let html = '';
                products.forEach(p => {
                    html += `<button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                             onclick='addProductToCart(${JSON.stringify(p)}, pendingQty)'>
                             <span>${p.name}</span> <span class="badge bg-primary en-numbers">${p.price.toFixed(2)}</span></button>`;
                });
                products.length > 0 ? $('#search-results').html(html).removeClass('d-none') : $('#search-results').addClass('d-none');
            };

            window.addProductToCart = function(product, qty) {
                let existing = cart.find(i => i.id === product.id);
                existing ? existing.qty += qty : cart.push({ id: product.id, name: product.name, price: product.price, qty: qty });
                $('#barcode-input').val('').focus();
                $('#search-results').addClass('d-none');
                updateUI();
                showQuickInfo(product);
            };

            function updateUI() {
                let html = ''; let total = 0;
                cart.forEach((item, i) => {
                    let rowTotal = item.price * item.qty;
                    total += rowTotal;
                    html += `<tr>
                        <td class="text-start fw-bold">${item.name}</td>
                        <td>${item.price.toFixed(2)}</td>
                        <td>
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <button class="btn btn-outline-danger btn-qty rounded-circle" onclick="updateQty(${i},-1)">-</button>
                                <span class="fw-bold fs-5 mx-2">${item.qty}</span>
                                <button class="btn btn-outline-success btn-qty rounded-circle" onclick="updateQty(${i},1)">+</button>
                            </div>
                        </td>
                        <td class="fw-bold text-primary">${rowTotal.toFixed(2)}</td>
                        <td><i class="fas fa-trash text-danger" style="cursor:pointer" onclick="remove(${i})"></i></td>
                    </tr>`;
                });
                $('#cart-items-body').html(html);
                $('#grand-total').text(total.toFixed(2));
                $('#items-count').text(cart.length);
            }

            window.updateQty = (i, d) => { cart[i].qty += d; if(cart[i].qty < 1) cart[i].qty = 1; updateUI(); };
            window.remove = (i) => { cart.splice(i, 1); updateUI(); };

            $('#btn-complete-sale').click(function() {
                if (cart.length === 0) return;
                const pType = parseInt($('#payment-type').val());
                if (pType === 2 && !$('#customer-id').val()) return Swal.fire('خطأ', 'يجب اختيار عميل للآجل', 'error');

                const saleData = {
                    shiftId: currentShiftId,
                    customerId: $('#customer-id').val() ? parseInt($('#customer-id').val()) : null,
                    paymentType: pType,
                    items: cart.map(i => ({ productId: i.id, quantity: i.qty, unitPrice: i.price })),
                    grandTotal: parseFloat($('#grand-total').text())
                };

                $.ajax({
                    url: '/Sales/Checkout',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(saleData),
                    success: function() { printInvoice(pType); },
                    error: function() { Swal.fire('خطأ', 'فشل حفظ الفاتورة', 'error'); }
                });
            });

            $('#btn-find-sale').click(function() {
                let saleId = $('#return-sale-id').val();
                if(!saleId) return;
                $.get(`/Sales/GetSaleDetails?saleId=${saleId}`, function(data) {
                    let html = '';
                    data.items.forEach(i => {
                        html += `<tr>
                            <td>${i.productName}</td>
                            <td>${i.quantity}</td>
                            <td><input type="number" class="form-control form-control-sm return-qty" data-id="${i.productId}" data-price="${i.unitPrice}" max="${i.quantity}" min="0" value="0"></td>
                            <td class="line-total en-numbers">0.00</td>
                        </tr>`;
                    });
                    $('#return-items-body').html(html);
                    $('#return-details, #btn-submit-return').removeClass('d-none');
                }).fail(() => Swal.fire('خطأ', 'رقم الفاتورة غير صحيح', 'error'));
            });

            $(document).on('input', '.return-qty', function() {
                let qty = parseFloat($(this).val()) || 0;
                let price = parseFloat($(this).data('price'));
                $(this).closest('tr').find('.line-total').text((qty * price).toFixed(2));
            });

            $('#btn-submit-return').click(function() {
                let items = [];
                let total = 0;
                $('.return-qty').each(function() {
                    let q = parseFloat($(this).val());
                    if(q > 0) {
                        items.push({ productId: parseInt($(this).data('id')), quantity: q, unitPrice: parseFloat($(this).data('price')) });
                        total += (q * parseFloat($(this).data('price')));
                    }
                });

                if(items.length === 0) return Swal.fire('تنبيه', 'حدد الكميات المرتجعة أولاً', 'info');

                const returnData = {
                    saleId: parseInt($('#return-sale-id').val()),
                    shiftId: currentShiftId,
                    reason: $('#return-reason').val() || "بدون سبب",
                    totalAmount: total,
                    items: items
                };

                $.ajax({
                    url: '/Sales/ProcessReturn',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(returnData),
                    success: function() {
                        Swal.fire('نجاح', 'تمت عملية المرتجع وتحديث المخزن', 'success').then(() => location.reload());
                    },
                    error: function() { Swal.fire('خطأ', 'فشل تنفيذ المرتجع', 'error'); }
                });
            });

            $(document).keydown(function(e) {
                if (e.which === 121) { e.preventDefault(); $('#btn-complete-sale').click(); } // F10
                if (e.which === 113) { e.preventDefault(); $('#barcode-input').focus(); } // F2
                if (e.which === 115) { e.preventDefault(); $('#returnModal').modal('show'); } // F4
            });
        });

        function printInvoice(type) {
            $('#p-date').text(new Date().toLocaleString());
            $('#p-type').text(type === 1 ? 'نقدي' : 'آجل');
            $('#p-total').text($('#grand-total').text());
            let rows = '';
            cart.forEach(i => { rows += `<tr><td>${i.name}</td><td style="text-align:center;">${i.qty}</td><td style="text-align:left;">${(i.price * i.qty).toFixed(2)}</td></tr>`; });
            $('#p-items').html(rows);

            const printContents = document.getElementById('print-receipt').innerHTML;
            const originalContents = document.body.innerHTML;
            document.body.innerHTML = printContents;
            window.print();
            document.body.innerHTML = originalContents;
            location.reload();
        }

        $(document).on('click', 'a[href*="CloseShift"]', function(e) {
            if (cart.length > 0) {
                e.preventDefault();
                let url = $(this).attr('href');
                Swal.fire({
                    title: 'تنبيه!',
                    text: "يوجد أصناف في السلة، هل أنت متأكد من مغادرة صفحة البيع وإغلاق الوردية؟",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'نعم، إغلاق الوردية',
                    cancelButtonText: 'تراجع'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            }
        });
    </script>
}