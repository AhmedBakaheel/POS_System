@model POS.Application.DTOs.ProductDTO

<div class="card shadow border-0">
    <div class="card-header bg-info text-white py-3">
        <h5 class="mb-0"><i class="fas fa-edit me-2"></i> تعديل بيانات المنتج: @Model.Name</h5>
    </div>
    <div class="card-body bg-light">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="row gx-4">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">اسم المنتج</label>
                    <input asp-for="Name" class="form-control form-control-lg shadow-sm" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">الباركود</label>
                    <input asp-for="Barcode" class="form-control form-control-lg shadow-sm en-numbers" required />
                </div>

                <hr class="my-4 text-secondary" />

                <div class="col-12 mb-3 text-info fw-bold">
                    <i class="fas fa-sync-alt me-1"></i> تحديث الأسعار والكميات (اختياري):
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label small">سعر الجملة الجديد</label>
                    <input type="number" id="bulk-cost" step="0.01" class="form-control bg-white en-numbers" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label small">القطع داخل الجملة</label>
                    <input type="number" id="items-per-box" step="0.01" value="1" class="form-control bg-white en-numbers" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label small">نسبة الربح (%)</label>
                    <input type="number" id="profit-percent" value="15" class="form-control bg-white en-numbers" />
                </div>
                <div class="col-md-3 mb-3 text-center">
                    <label class="form-label small d-block text-muted">إعادة حساب؟</label>
                    <button type="button" onclick="calculateSmartValues()" class="btn btn-outline-info btn-sm">تطبيق الحساب</button>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-danger">تكلفة الوحدة الحالية</label>
                    <input asp-for="Cost" type="number" step="0.0001" class="form-control form-control-lg border-danger en-numbers" id="final-cost" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-success">سعر البيع الحالي</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg border-success en-numbers" id="final-price" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-primary">الكمية المتوفرة (مباشر)</label>
                    <input asp-for="StockQuantity" type="number" step="0.01" class="form-control form-control-lg border-primary en-numbers" id="final-stock" required />
                    <small class="text-muted text-truncate d-block">تعديل هذا الحقل يغير المخزون فوراً.</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-warning">حد الطلب (Reorder Level)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning bg-opacity-10"><i class="fas fa-bell"></i></span>
                        <input asp-for="ReorderLevel" type="number" step="0.01" class="form-control form-control-lg border-warning en-numbers" required />
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold">الصنف (Category)</label>
                    <select asp-for="CategoryId" class="form-select form-select-lg shadow-sm" asp-items="ViewBag.Categories" required>
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2 border-top pt-4">
                <button type="submit" class="btn btn-info btn-lg px-5 shadow text-white">
                    <i class="fas fa-save me-1"></i> حفظ التعديلات
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calculateSmartValues() {
            let bulkCost = parseFloat($('#bulk-cost').val()) || 0;
            let itemsPerBox = parseFloat($('#items-per-box').val()) || 1;
            let profitMargin = parseFloat($('#profit-percent').val()) || 0;

            if (bulkCost > 0) {
                let unitCost = bulkCost / itemsPerBox;
                $('#final-cost').val(unitCost.toFixed(4));

                let unitPrice = unitCost + (unitCost * (profitMargin / 100));
                $('#final-price').val(unitPrice.toFixed(2));
            } else {
                alert("يرجى إدخال سعر جملة صحيح للحساب.");
            }
        }

        $(document).ready(function () {
            $('.en-numbers').on('input', function() {
                this.value = this.value.replace(/[٠-٩]/g, d => d.charCodeAt(0) - 1632)
                                       .replace(/[۰-۹]/g, d => d.charCodeAt(0) - 1776);
            });
        });
    </script>
}