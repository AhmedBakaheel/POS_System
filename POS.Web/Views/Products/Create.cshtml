@model POS.Application.DTOs.ProductDTO

<div class="card shadow border-0">
    <div class="card-header bg-dark text-white py-3">
        <h5 class="mb-0"><i class="fas fa-box-open me-2 text-warning"></i> إضافة منتج جديد (حساب ذكي للمخزون)</h5>
    </div>
    <div class="card-body bg-light">
        <form asp-action="Create" id="productForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row gx-4">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-dark">اسم المنتج</label>
                    <input asp-for="Name" class="form-control form-control-lg shadow-sm" placeholder="مثال: أرز بسمتي 5 كيلو" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-dark">الباركود</label>
                    <input asp-for="Barcode" class="form-control form-control-lg shadow-sm en-numbers" placeholder="00000000" required />
                </div>

                <hr class="my-4 text-secondary" />

                <div class="col-12 mb-3 text-primary fw-bold">
                    <i class="fas fa-calculator me-1"></i> حاسبة التكلفة والكمية (دقة عشرية):
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label small">سعر شراء الجملة (الكرتون)</label>
                    <input type="number" id="bulk-cost" step="0.01" class="form-control bg-white en-numbers" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label small">الكمية داخل الجملة (عدد/وزن)</label>
                    <input type="number" id="items-per-box" step="0.01" value="1" class="form-control bg-white en-numbers" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label small">عدد وحدات الجملة المشتراة</label>
                    <input type="number" id="num-boxes" step="0.01" value="0" class="form-control bg-warning bg-opacity-10 en-numbers" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label small">نسبة الربح (%)</label>
                    <div class="input-group">
                        <input type="number" id="profit-percent" value="15" class="form-control bg-white en-numbers" />
                        <span class="input-group-text">%</span>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-danger">تكلفة الوحدة</label>
                    <input asp-for="Cost" type="number" step="0.0001" class="form-control form-control-lg border-danger bg-white en-numbers" required id="final-cost" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-success">سعر البيع</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg border-success bg-white en-numbers" required id="final-price" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold text-primary">إجمالي الكمية المتوفرة</label>
                    <input asp-for="StockQuantity" type="number" step="0.01" class="form-control form-control-lg border-primary bg-light en-numbers" readonly id="final-stock" />
                    <small class="text-muted">بالكيلو أو بالقطعة (Decimal)</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-warning">حد الطلب (تنبيه النواقص)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning bg-opacity-10"><i class="fas fa-bell"></i></span>
                        <input asp-for="ReorderLevel" type="number" step="0.01" class="form-control form-control-lg border-warning en-numbers" placeholder="مثال: 10.5" required />
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold text-dark">الصنف (Category)</label>
                    <select asp-for="CategoryId" class="form-select form-select-lg shadow-sm" asp-items="ViewBag.Categories" required>
                        <option value="">-- اختر الصنف --</option>
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2 border-top pt-4">
                <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                    <i class="fas fa-save me-1"></i> حفظ المنتج
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">إلغاء</a>
            </div>
        </form>
    </div>
</div>

<style>
    #final-stock {
        font-weight: bold;
        color: #0d6efd;
        background-color: #f0f7ff !important;
    }

    input[readonly] {
        cursor: not-allowed;
    }

    .en-numbers {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
        direction: ltr !important;
        text-align: left;
    }

    .form-control-lg {
        border-radius: 8px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            function convertArToEn(str) {
                return str.replace(/[٠-٩]/g, d => d.charCodeAt(0) - 1632)
                          .replace(/[۰-۹]/g, d => d.charCodeAt(0) - 1776);
            }

            $('.en-numbers').on('input', function() {
                let currentVal = $(this).val();
                $(this).val(convertArToEn(currentVal));
                calculateSmartValues();
            });

            function calculateSmartValues() {
                let bulkCost = parseFloat($('#bulk-cost').val()) || 0;
                let itemsPerBox = parseFloat($('#items-per-box').val()) || 1;
                let numBoxes = parseFloat($('#num-boxes').val()) || 0;
                let profitMargin = parseFloat($('#profit-percent').val()) || 0;

                let totalStock = (numBoxes * itemsPerBox).toFixed(2);
                $('#final-stock').val(totalStock);

                let unitCost = bulkCost / (itemsPerBox > 0 ? itemsPerBox : 1);
                $('#final-cost').val(unitCost.toFixed(4));

                let unitPrice = unitCost + (unitCost * (profitMargin / 100));
                $('#final-price').val(unitPrice.toFixed(2));
            }

            $('#bulk-cost, #items-per-box, #num-boxes, #profit-percent').on('change keyup', calculateSmartValues);
        });
    </script>
}