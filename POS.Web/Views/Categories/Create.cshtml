@model POS.Application.DTOs.CategoryDTO

@{
    ViewData["Title"] = "إضافة صنف جديد";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>إضافة صنف جديد للمخزون</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">اسم الصنف</label>
                            <input asp-for="Name" class="form-control" placeholder="مثال: مواد غذائية، منظفات..." required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">وصف الصنف</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="اكتب وصفاً مختصراً للصنف هنا..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-save me-1"></i> حفظ البيانات
                            </button>
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-arrow-right me-1"></i> العودة للقائمة
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}