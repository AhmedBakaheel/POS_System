@using POS.Application.ViewModels
@model CustomerViewModel

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>إضافة عميل جديد</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم العميل</label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="أدخل اسم العميل بالكامل" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control form-control-lg" placeholder="00967XXXXXXXX" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">الرصيد الافتتاحي (مديونية سابقة)</label>
                        <input asp-for="InitialBalance" type="number" step="any" class="form-control form-control-lg" value="0" />
                        <small class="text-muted">أدخل مديونية العميل السابقة إن وجدت، أو اتركها صفراً.</small>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>حفظ بيانات العميل
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء والعودة للقائمة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}