@using POS.Web.ViewModel
@model LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>الدخول إلى النظام | POS Pro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: #1a1a2e; /* خلفية داكنة احترافية */
            background-image: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-box {
            width: 100%;
            max-width: 450px;
            padding: 15px;
        }

        .card {
            border: none;
            border-radius: 20px;
            background: #ffffff;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        .login-logo {
            font-size: 50px;
            color: #0f3460;
        }

        .btn-login {
            background: #e94560;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: bold;
            font-size: 18px;
            color: white;
        }

            .btn-login:hover {
                background: #cf3a54;
            }

        .form-control {
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="card p-4">
            <div class="text-center mb-4">
                <div class="login-logo mb-2">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="fw-bold text-dark">نظام POS الاحترافي</h3>
                <p class="text-muted small">يرجى تسجيل الدخول لمتابعة العمل</p>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">اسم المستخدم</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-user text-muted"></i></span>
                        <input asp-for="Username" class="form-control" placeholder="أدخل اسمك (بالعربي أو الإنجليزي)" autofocus>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">كلمة المرور</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-key text-muted"></i></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="******">
                    </div>
                </div>

                <div class="mb-3 d-flex justify-content-between">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input">
                        <label class="form-check-label small" asp-for="RememberMe">تذكرني</label>
                    </div>
                    <a href="#" class="small text-decoration-none">نسيت كلمة المرور؟</a>
                </div>

                <button type="submit" class="btn btn-login w-100 shadow">
                    تسجيل الدخول <i class="fas fa-arrow-left ms-2"></i>
                </button>
            </form>
        </div>
        <div class="text-center mt-4 text-white-50">
            <small>الإصدار 3.0 &copy; 2026</small>
        </div>
    </div>

</body>
</html>